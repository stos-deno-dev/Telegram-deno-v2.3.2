# Telegram Bot Configuration
# ⚠️ IMPORTANT: Do not commit actual values to this file
# Use environment variables or your hosting platform's secret management

# Bot token from Telegram BotFather
# Set via environment variable: BOT_TOKEN
BOT_TOKEN=${BOT_TOKEN}

# Webhook secret for secure communication
# Set via environment variable: WEBHOOK_SECRET
WEBHOOK_SECRET=${WEBHOOK_SECRET}

# Owner/Admin Telegram ID
# Set via environment variable: OWNER_ID
OWNER_ID=${OWNER_ID}

# Webhook URL for receiving updates
# Set via environment variable: WEBHOOK_URL
WEBHOOK_URL=${WEBHOOK_URL}
